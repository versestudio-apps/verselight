<?xml version="1.0" encoding="utf-8"?>
<!-- VerseLight launch background. Cream base transitions smoothly into the
     in-app scaffoldBackgroundColor (AppColors.ivory). Centered brand symbol
     reuses the launcher foreground so no extra assets are introduced. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/brand_cream" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_launcher_foreground" />
    </item>
</layer-list>
